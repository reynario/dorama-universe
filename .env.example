# String de conexao do Postgres (Supabase). Use a connection string "Session/Pooler".
DATABASE_URL=postgresql://usuario:senha@host:5432/postgres

# Segredo do Payload (gere um aleatorio: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PAYLOAD_SECRET=YOUR_SECRET_HERE

# URL publica do admin/API (em dev fica localhost)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# --- Cloudflare R2 (imagens) - preencher na Fase 3 ---
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
